/* === 全局样式变量 === */
page {
  --color-primary: #FF6B35;
  --color-primary-dark: #FF5722;
  --color-link: #1A73E8;
  --color-green: #34A853;
  --color-yellow: #FBBC04;
  --color-red: #EA4335;
  --color-bg: #f5f5f5;
  --color-card: #ffffff;
  --color-text: #333333;
  --color-text-secondary: #666666;
  --color-text-hint: #999999;
  --color-border: #e0e0e0;
  --color-divider: #f0f0f0;
  --radius-card: 12pt;
  --radius-btn: 8pt;
  --radius-lg: 20px;
  --font-system: -apple-system, 'PingFang SC', 'Helvetica Neue', sans-serif;

  font-family: var(--font-system);
  font-size: 14px;
  color: var(--color-text);
  background: var(--color-bg);
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

/* === 工具类 === */
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.text-center { text-align: center; }
.mt-8 { margin-top: 8px; }
.mt-12 { margin-top: 12px; }
.mt-16 { margin-top: 16px; }
.mb-8 { margin-bottom: 8px; }
.mb-12 { margin-bottom: 12px; }
.mb-16 { margin-bottom: 16px; }

/* === 按钮 === */
.btn-primary {
  width: 100%;
  height: 50px;
  background: linear-gradient(135deg, var(--color-primary), var(--color-primary-dark));
  border: none;
  border-radius: var(--radius-btn);
  color: #fff;
  font-size: 17px;
  font-weight: 700;
  box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
  transition: transform 0.15s;
}
.btn-primary:active { transform: scale(0.98); }

.btn-outline {
  width: 100%;
  height: 44px;
  border: 2px solid var(--color-primary);
  border-radius: var(--radius-btn);
  background: #fff;
  color: var(--color-primary);
  font-size: 15px;
  font-weight: 600;
}

/* === 卡片 === */
.card {
  background: var(--color-card);
  border-radius: var(--radius-card);
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}

.card-title {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 12px;
}

/* === 状态指示器 === */
.status-indicator {
  display: inline-flex;
  align-items: center;
  gap: 4px;
}
.status-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  display: inline-block;
}
.status-dot.green { background: var(--color-green); }
.status-dot.yellow { background: var(--color-yellow); }
.status-dot.red { background: var(--color-red); }
.status-shape {
  font-size: 10px;
  margin-left: 2px;
}

/* === 底部Sheet通用 === */
.sheet-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 100;
}
.sheet-panel {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-radius: 20px 20px 0 0;
  padding: 20px 16px 40px;
  z-index: 101;
  animation: sheetSlideUp 0.3s ease;
}
@keyframes sheetSlideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}
.sheet-handle {
  width: 36px;
  height: 4px;
  background: #ddd;
  border-radius: 2px;
  margin: 0 auto 16px;
}

/* === 标签 === */
.badge {
  display: inline-block;
  background: linear-gradient(135deg, #FFD700, #FFA500);
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 10px;
}
.tag {
  display: inline-block;
  background: #f0f7ff;
  color: var(--color-link);
  font-size: 12px;
  padding: 3px 8px;
  border-radius: 6px;
}
.scene-tag {
  display: inline-block;
  background: #FFF0E5;
  color: var(--color-primary);
  font-size: 11px;
  font-weight: 600;
  padding: 3px 8px;
  border-radius: 8px;
}
.quality-tag {
  background: var(--color-divider);
  border-radius: 8px;
  padding: 5px 10px;
  font-size: 12px;
  color: var(--color-text);
  display: inline-flex;
  align-items: center;
  gap: 4px;
}

/* === 加载动画 === */
.loading-spinner {
  width: 48px;
  height: 48px;
  border: 4px solid var(--color-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
