/* pages/nav/nav.wxss - 导航引导页样式（上下分屏布局） */

.nav-page {
  width: 100vw;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* === 上部地图区域 === */
.nav-map-area {
  flex: 0 0 45%;
  position: relative;
}
.nav-map {
  width: 100%;
  height: 100%;
}

/* === 下部步骤卡片区域 === */
.nav-steps-area {
  flex: 1;
  background: #fff;
  border-radius: 20px 20px 0 0;
  margin-top: -16px;
  position: relative;
  z-index: 10;
}

.nav-steps-card {
  padding: 20px 20px 40px;
}

/* 目的地信息 */
.nav-destination {
  margin-bottom: 16px;
}
.nav-dest-name {
  font-size: 18px;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 6px;
}
.nav-dest-meta {
  display: flex;
  gap: 16px;
  font-size: 13px;
}
.nav-dest-status {
  color: #34A853;
  font-weight: 500;
}
.nav-dest-walk {
  color: #666;
}

/* 步骤列表 */
.nav-steps {
  margin-bottom: 20px;
}
.nav-steps-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 12px;
}

.nav-step {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 12px;
  font-size: 14px;
  line-height: 1.5;
}

.nav-step:last-child {
  margin-bottom: 0;
}

.step-num {
  width: 24px;
  height: 24px;
  background: #FF6B35;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  font-weight: 700;
  color: #fff;
  flex-shrink: 0;
}

.step-text {
  color: #333;
  flex: 1;
}

/* 底部按钮区 */
.nav-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.nav-start-btn {
  width: 100%;
  height: 50px;
  background: linear-gradient(135deg, #FF6B35, #FF5722);
  border: none;
  border-radius: 12px;
  color: #fff;
  font-size: 17px;
  font-weight: 700;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-tip-text {
  font-size: 12px;
  color: #999;
  margin-bottom: 16px;
  text-align: center;
}

.nav-arrive-btn {
  width: 100%;
  height: 44px;
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 12px;
  color: #333;
  font-size: 15px;
  font-weight: 500;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-feedback-link {
  font-size: 14px;
  color: #999;
  text-decoration: underline;
}
