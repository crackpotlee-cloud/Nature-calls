/* pages/success/success.wxss - 反馈成功页样式 */

.page-container {
  width: 100vw;
  height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
}

.success-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40px 32px;
}

.success-emoji {
  font-size: 64px;
  margin-bottom: 20px;
}

.success-title {
  font-size: 20px;
  font-weight: 700;
  color: #333;
  margin-bottom: 8px;
  text-align: center;
}

.success-desc {
  font-size: 14px;
  color: #999;
  text-align: center;
  margin-bottom: 40px;
  line-height: 1.6;
  white-space: pre-line;
}
