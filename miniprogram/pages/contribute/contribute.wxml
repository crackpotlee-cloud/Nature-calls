<!-- pages/contribute/contribute.wxml - 贡献厕所页 -->
<view class="page-container">

  <!-- 头部 -->
  <view class="contribute-header">
    <text class="contribute-back" bindtap="onBack">←</text>
    <text class="contribute-title">贡献厕所</text>
  </view>

  <!-- 步骤指示器 -->
  <view class="step-indicator">
    <view wx:for="{{totalSteps}}" wx:key="index" class="step-dot {{index < currentStep ? 'active' : ''}}"></view>
  </view>

  <scroll-view scroll-y class="contribute-scroll">
    <view class="contribute-content">

      <!-- Step 1: 位置选择 -->
      <view class="card" wx:if="{{currentStep === 1}}">
        <text class="contribute-label">📍 选择位置 <text class="required">*</text></text>
        <view class="location-picker" bindtap="onChooseLocation">
          <text class="location-picker-icon">🗺️</text>
          <text wx:if="{{!formData.location}}" class="location-picker-hint">点击选择厕所位置</text>
          <text wx:else class="location-picker-val">已选：{{formData.location.address}}</text>
        </view>
      </view>

      <!-- Step 2: 名称 + 类型 -->
      <view class="card" wx:if="{{currentStep === 2}}">
        <text class="contribute-label">名称 <text class="required">*</text></text>
        <input class="contribute-input" placeholder="如：IFS 3F 海底捞旁" value="{{formData.name}}" bindinput="onInput" data-field="name" />
        
        <text class="contribute-label mt-16">类型 <text class="required">*</text></text>
        <view class="chip-group">
          <view wx:for="{{toiletTypes}}" wx:key="*this" 
            class="chip {{formData.type === item ? 'selected' : ''}}" 
            bindtap="onSelectType" data-value="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <!-- Step 3: 锚点 + 楼层 + 路径 -->
      <view class="card" wx:if="{{currentStep === 3}}">
        <text class="contribute-label">锚点品牌 <text class="required">*</text></text>
        <input class="contribute-input" placeholder="如：海底捞" value="{{formData.landmark}}" bindinput="onInput" data-field="landmark" />
        
        <text class="contribute-label mt-16">楼层 <text class="required">*</text></text>
        <input class="contribute-input" placeholder="如：3F" value="{{formData.floor}}" bindinput="onInput" data-field="floor" />
        
        <text class="contribute-label mt-16">路径指引 <text class="required">*</text></text>
        <textarea class="contribute-textarea" placeholder="描述从入口如何找到厕所..." value="{{formData.direction}}" bindinput="onInput" data-field="direction" />
      </view>

      <!-- Step 4: 准入类型 -->
      <view class="card" wx:if="{{currentStep === 4}}">
        <text class="contribute-label">准入类型 <text class="required">*</text></text>
        <view class="chip-group">
          <view wx:for="{{accessTypes}}" wx:key="*this"
            class="chip {{formData.access_type === item ? 'selected' : ''}}"
            bindtap="onSelectType" data-value="{{item}}">
            {{item}}
          </view>
        </view>
      </view>

      <!-- Step 5: 设施 -->
      <view class="card" wx:if="{{currentStep === 5}}">
        <text class="contribute-label">设施清单 <text class="required">*</text></text>
        <view class="facility-list">
          <view wx:for="{{facilities}}" wx:key="key"
            class="facility-chip {{formData.facilities[item.key] ? 'selected' : ''}}"
            bindtap="onToggleFacility" data-key="{{item.key}}">
            <text>{{item.icon}} {{item.name}}</text>
          </view>
        </view>
      </view>

      <!-- Step 6: 确认提交 -->
      <view class="card" wx:if="{{currentStep === 6}}">
        <text class="contribute-label">确认信息</text>
        <view class="confirm-list">
          <view class="confirm-item">
            <text class="confirm-key">位置</text>
            <text class="confirm-val">{{formData.location ? formData.location.address : '未选择'}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-key">名称</text>
            <text class="confirm-val">{{formData.name || '未填写'}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-key">类型</text>
            <text class="confirm-val">{{formData.type || '未选择'}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-key">锚点</text>
            <text class="confirm-val">{{formData.landmark || '未填写'}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-key">楼层</text>
            <text class="confirm-val">{{formData.floor || '未填写'}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-key">路径</text>
            <text class="confirm-val confirm-val-long">{{formData.direction || '未填写'}}</text>
          </view>
          <view class="confirm-item">
            <text class="confirm-key">准入</text>
            <text class="confirm-val">{{formData.access_type || '未选择'}}</text>
          </view>
        </view>
      </view>

      <!-- 导航按钮 -->
      <view class="step-buttons">
        <button wx:if="{{currentStep > 1}}" class="btn-outline" style="width:auto;padding:0 24px" bindtap="onPrevStep">上一步</button>
        <button wx:if="{{currentStep < totalSteps}}" class="btn-primary" style="width:auto;padding:0 24px;flex:1" bindtap="onNextStep">下一步</button>
        <button wx:if="{{currentStep === totalSteps}}" class="btn-primary" bindtap="onSubmit">提交审核</button>
      </view>

    </view>
  </scroll-view>

</view>
