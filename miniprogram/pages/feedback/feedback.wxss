/* pages/feedback/feedback.wxss - 反馈页样式 */

.page-container {
  width: 100vw;
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.feedback-sheet {
  flex: 1;
  background: #fff;
  padding: 24px 20px 40px;
  margin-top: 44px;
}

.feedback-title {
  font-size: 17px;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 6px;
}

.feedback-subtitle {
  font-size: 13px;
  color: #999;
  display: block;
  margin-bottom: 24px;
}

/* 问题 */
.feedback-q {
  margin-bottom: 18px;
}

.q-label {
  font-size: 14px;
  font-weight: 600;
  color: #555;
  display: block;
  margin-bottom: 8px;
}

/* 选项 */
.q-options {
  display: flex;
  gap: 8px;
}
.q-options.three-col .opt-btn {
  flex: 1;
}

.opt-btn {
  flex: 1;
  height: 44px;
  border: 2px solid #e0e0e0;
  border-radius: 10px;
  background: #fff;
  font-size: 14px;
  color: #555;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 4px;
  transition: all 0.15s;
}

.opt-btn:active,
.opt-btn.selected {
  border-color: #FF6B35;
  background: #FFF5F0;
  color: #FF6B35;
}

.opt-btn.good.selected {
  border-color: #34A853;
  background: #E8F5E9;
  color: #34A853;
}

.opt-btn.bad.selected {
  border-color: #EA4335;
  background: #FFEBEE;
  color: #EA4335;
}

/* 提交按钮 */
.feedback-submit {
  width: 100%;
  height: 50px;
  background: linear-gradient(135deg, #FF6B35, #FF5722);
  border: none;
  border-radius: 12px;
  color: #fff;
  font-size: 16px;
  font-weight: 700;
  margin-top: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-submit[disabled] {
  background: #ccc;
  color: #fff;
}

/* 跳过 */
.feedback-skip {
  text-align: center;
  font-size: 14px;
  color: #999;
  margin-top: 16px;
  display: block;
}

/* sheet handle */
.sheet-handle {
  width: 36px;
  height: 4px;
  background: #ddd;
  border-radius: 2px;
  margin: 0 auto 20px;
}
